# Application
APP_NAME=go_template
APP_ENV=development
LOG_LEVEL=debug

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

# Database: switch DB_DRIVER between "postgres" and "mongo".
# This single value is the only change needed to swap databases.
DB_DRIVER=postgres
# Postgres example:
DB_URI=postgres://postgres:postgres@localhost:5432/go_template?sslmode=disable
# Mongo example (uncomment and set DB_DRIVER=mongo):
# DB_URI=mongodb://localhost:27017
MONGO_DATABASE=go_template
DB_MAX_OPEN_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_CONN_TIMEOUT=5s

# Cache: switch CACHE_DRIVER between "memory" and "redis".
CACHE_DRIVER=memory
CACHE_TTL=5m
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Message queue: switch QUEUE_DRIVER between "memory" and "redis".
QUEUE_DRIVER=memory
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF=1s

# Rate limiting (per user ID when authenticated, otherwise per IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# HTTP per-request timeout
HTTP_REQUEST_TIMEOUT=30s

# Auth
JWT_SECRET=change-me-in-production
JWT_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=go_template
